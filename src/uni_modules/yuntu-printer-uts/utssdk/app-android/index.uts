        return
      }
      try {
        const esc = createEscBuilder()
        esc.escThreeColumn(options.leftText, options.middleText, options.rightText,
          (options.middlePositionDots ?? 200).toInt(),
          (options.paperWidthDots ?? 384).toInt(),
          (options.charWidthDots ?? 12).toInt())
        if (options.autoOut == true) {
          esc.addPrintAndFeedLines(3)
          esc.escCutPaper()
        }
        const response = printNoryoxEscposData(service, bytesToNative(esc.bytes))
        if (response != null && response.size > 0) {
          emitDataReceive(bytesFromNative(response))
        }
        resolve(createBuiltInResult(0))
      } catch (error) {
        reject(createPrinterError(PRINTER_ERROR_WRITE_FAILED, `Failed to print Noryox built-in threeColumn: ${error}`))
      }
    }).start()
  })
}

export function printBuiltInFourColumn(options: PrintBuiltInFourColumnOptions): Promise<BuiltInPrinterResult> {
  return new Promise<BuiltInPrinterResult>((resolve, reject) => {
    if (options.oneText.length == 0 && options.twoText.length == 0 && options.threeText.length == 0 && options.fourText.length == 0) {
      reject(createPrinterError(PRINTER_ERROR_INVALID_PAYLOAD, 'Built-in fourColumn texts are empty.'))
      return
    }
    Thread(() => {
      const service = noryoxPrinterService
      if (service == null) {
        reject(createPrinterError(PRINTER_ERROR_SERVICE_NOT_CONNECTED, 'Noryox printer service is not connected.'))
        return
      }
      try {
        const esc = createEscBuilder()
        esc.escFourColumn(options.oneText, options.twoText, options.threeText, options.fourText,
          (options.twoPositionDots ?? 140).toInt(),
          (options.threePositionDots ?? 260).toInt(),
          (options.paperWidthDots ?? 384).toInt(),
          (options.charWidthDots ?? 12).toInt())
        if (options.autoOut == true) {
          esc.addPrintAndFeedLines(3)
          esc.escCutPaper()
        }
        const response = printNoryoxEscposData(service, bytesToNative(esc.bytes))
        if (response != null && response.size > 0) {
          emitDataReceive(bytesFromNative(response))
        }
        resolve(createBuiltInResult(0))
      } catch (error) {
        reject(createPrinterError(PRINTER_ERROR_WRITE_FAILED, `Failed to print Noryox built-in fourColumn: ${error}`))
      }
    }).start()
  })
}

export function scanPrinters(options?: ScanPrintersSimpleOptions): Promise<ScanPrintersSuccess> {
  return new Promise<ScanPrintersSuccess>((resolve, reject) => {
    scanPrintersInternal({ timeout: options?.timeout ?? 10000, serviceUUIDs: options?.serviceUUIDs, success: (res: ScanPrintersSuccess) => { resolve(res) }, fail: (err: PrinterError) => { reject(err) } })
  })
}

export function connectPrinter(options: ConnectPrinterSimpleOptions): Promise<PrinterConnection> {
  return new Promise<PrinterConnection>((resolve, reject) => {
    connectPrinterInternal({
      deviceId: options.deviceId,
      serviceUUIDs: options.serviceUUIDs,
      writeCharacteristicUUIDs: options.writeCharacteristicUUIDs,
      timeout: options.timeout,
      success: (res: PrinterConnection) => { resolve(res) },
      fail: (err: PrinterError) => { reject(err) },
    })
  })
}

export function connectWifi(options: ConnectWifiSimpleOptions): Promise<PrinterConnection> {
  return new Promise<PrinterConnection>((resolve, reject) => {
    connectNetInternal({
      ip: options.ip,
      port: options.port,
      timeout: options.timeout,
      success: (res: PrinterConnection) => { resolve(res) },
      fail: (err: PrinterError) => { reject(err) },
    })
  })
}

export function disconnectPrinter(): Promise<boolean> {
  return new Promise<boolean>((resolve, reject) => {
    disconnectPrinterInternal({ success: () => resolve(true), fail: (err: PrinterError) => { reject(err) } })
  })
}

export function getConnectedPrinter(): PrinterConnection | null {
  return connectedPrinter
}

export function checkBuiltInPrinter(): Promise<CheckBuiltInPrinterSuccess> {
  return new Promise<CheckBuiltInPrinterSuccess>((resolve, reject) => {
    checkBuiltInPrinterInternal({ success: (res: CheckBuiltInPrinterSuccess) => { resolve(res) }, fail: (err: PrinterError) => { reject(err) } })
  })
}

export function testPrint(options: ConnectPrinterSimpleOptions): Promise<WriteDataResult> {
  return new Promise<WriteDataResult>((resolve, reject) => {
    connectPrinterInternal({
      deviceId: options.deviceId,
      serviceUUIDs: options.serviceUUIDs,
      writeCharacteristicUUIDs: options.writeCharacteristicUUIDs,
      timeout: options.timeout,
      success: (_connection: PrinterConnection) => {
        const bytes = [...buildTestPrintEsc().bytes]
        const chunkSize = getDefaultChunkSize(bytes)
        const chunks = splitBytes(bytes, chunkSize)
        printEscInternal({
          bytes,
          chunkSize,
          success: () => {
            disconnectPrinterInternal({
              success: () => resolve({ byteLength: bytes.length, chunkCount: chunks.length, complete: true, msg: 'ok' }),
              fail: (_err: PrinterError) => resolve({ byteLength: bytes.length, chunkCount: chunks.length, complete: true, msg: 'ok' }),
            })
          },
          fail: (err: PrinterError) => {
            disconnectPrinterInternal({
              success: () => reject(err),
              fail: (_disconnectErr: PrinterError) => reject(err),
            })
          },
        })
      },
      fail: (err: PrinterError) => { reject(err) },
    })
  })
}

export function printText(options: PrintTextSimpleOptions): Promise<WriteDataResult> {
  return new Promise<WriteDataResult>((resolve, reject) => {
    printTextInternal({
      title: options.title,
      lines: options.lines,
      feed: options.feed,
      cut: options.cut,
      chunkSize: options.chunkSize,
      success: () => resolve({ byteLength: 0, chunkCount: 0, complete: true, msg: 'ok' }),
      fail: (err: PrinterError) => { reject(err) },
    })
  })
}

export function printEsc(bytes: number[], chunkSize?: number): Promise<WriteDataResult> {
  return new Promise<WriteDataResult>((resolve, reject) => {
    printEscInternal({ bytes, chunkSize, success: () => resolve({ byteLength: bytes.length, chunkCount: 1, complete: true, msg: 'ok' }), fail: (err: PrinterError) => { reject(err) } })
  })
}

export function onConnectStateChange(callback: ConnectStateCallback) {
  connectStateCallback = callback
}

// ============================================================
// Internal helpers (non-exported — used by new API)
// ============================================================

function printEscInternal(options: PrintEscOptions) {
  if (options.bytes.length == 0) {
    options.fail?.(createPrinterError(PRINTER_ERROR_INVALID_PAYLOAD, 'ESC payload is empty.'))
    runComplete(options.complete ?? null)
    return
  }

  writeBytes(options.bytes, options.chunkSize ?? getDefaultChunkSize(options.bytes), () => {
    options.success?.()
    runComplete(options.complete ?? null)
  }, (message: string) => {
    const code = message == 'Printer is not connected.' ? PRINTER_ERROR_NOT_CONNECTED : PRINTER_ERROR_WRITE_FAILED
    options.fail?.(createPrinterError(code, message))
    runComplete(options.complete ?? null)
  })
}

function printTextInternal(options: PrintTextOptions) {
  const payload: ReceiptPayload = {
    title: options.title,
    lines: options.lines,
    feed: options.feed,
    cut: options.cut,
  }
  printEscInternal({
    bytes: buildReceipt(payload),
    chunkSize: options.chunkSize,
    success: options.success,
    fail: options.fail,
    complete: options.complete,
  })
}
